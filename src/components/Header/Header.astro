    </div>
    <Button
        classCustom="z-10"
        size="sm"
        target={"_blank"}
        href={"https://api.whatsapp.com/send/?phone=933288124"}
    >
        Contactame
    </Button>
</div>

<!-- Modal -->
<div
    class="modal fixed inset-0 hidden items-center justify-center bg-transparent z-50"
    id="modal"
>
    <div class="bg-[#1F1F23] p-6 rounded shadow-lg md:h-[80%] md:w-[50%] sm:h-[100%] sm:w-[100%]  h-full w-full">
        <div class="flex justify-between items-start">
            <h2 class="text-xl text-white font-bold mb-4">Curriculum Vitae</h2>
            <svg
                id="modal-toggle"
                class="cursor-pointer"
                width="25px"
                height="25px"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
            >
                <path
                    d="M20.7457 3.32851C20.3552 2.93798 19.722 2.93798 19.3315 3.32851L12.0371 10.6229L4.74275 3.32851C4.35223 2.93798 3.71906 2.93798 3.32854 3.32851C2.93801 3.71903 2.93801 4.3522 3.32854 4.74272L10.6229 12.0371L3.32856 19.3314C2.93803 19.722 2.93803 20.3551 3.32856 20.7457C3.71908 21.1362 4.35225 21.1362 4.74277 20.7457L12.0371 13.4513L19.3315 20.7457C19.722 21.1362 20.3552 21.1362 20.7457 20.7457C21.1362 20.3551 21.1362 19.722 20.7457 19.3315L13.4513 12.0371L20.7457 4.74272C21.1362 4.3522 21.1362 3.71903 20.7457 3.32851Z"
                    fill="#fff"></path>
            </svg>
        </div>
        <hr />
        <embed
            src="/public/docs/PedroSandovalCV.docx.pdf"
            type="application/pdf"
            width="100%"
            height="100%"
        />
    </div>
</div>

<script is:inline>
    const buttonContactMe = document.getElementById("button-contact-me");
    const buttonredirection = document.getElementById("button-contact-me");
    const openBtn = document.getElementById("open-modal");
    const modal = document.getElementById("modal");
    const modalClose = document.getElementById("modal-toggle");

    // buttonContactMe.addEventListener("click", (e) => {
    //     e.preventDefault(); // Prevent default anchor click behavior
    //     const contactMeSection = document.getElementById("contact-me");
    //     if (contactMeSection) {
    //         // Scroll to the contact-me section smoothly
    //         contactMeSection.scrollIntoView({ behavior: "smooth" });
    //     } else {
    //         console.error("Element with ID 'contact-me' not found.");
    //     }
    // });

    openBtn.addEventListener("click", () => {
        modal.style.display = "flex";
        document.body.style.overflow = "hidden";
    });

    modalClose.addEventListener("click", () => {
        modal.style.display = "none";
        document.body.style.overflow = "";
    });
</script>

<style>
    #modal-toggle:checked ~ .modal {
        display: flex;
    }
</style>

---
import Button from "../UI/Button.astro";
import ContainerIconsDinamic from "../UI/ContainerIconsDinamic.astro";

interface Props {
    title: string;
    description: string;
    urlImage: string;
}

const currentYear = new Date().getFullYear();

const { title, description, urlImage } = Astro.props;
---

<div
    id="header"
    class="relative flex flex-col items-center justify-center bg-cover bg-center h-full
        intersect-once intersect-quarter md:intersect:animate-fade border-b-1 border-b-indigo-500 m-auto"
    style={`--bg-url: url('${urlImage}')`}
>
    <div
        class="absolute inset-0 bg-[image:var(--bg-url)] bg-cover bg-center opacity-60 max-w-[100rem] m-auto"
    >
    </div>
    <div class="relative z-12 text-center px-4 pt-12">
        <h1 class="text-6xl z-12 text-white md:text-5xl font-medium">
            {title}
        </h1>
        <p class="mt-1 text-lg z-12 text-white max-w-2xl mx-auto font-thin">
            {description}
        </p>
    </div>
    <div class=" flex justify-center items-center">
        <!-- Contenedor de tres columnas -->
        <div class="grid grid-cols-1 gap-8">
            <h4
                class="text-xl text-center font-semibold text-black-rich mb-4 text-white z-10"
            >
                <div class="mt-3">
                    <div
                        class="text-xl flex justify-center md:block font-semibold text-black-rich mb-0"
                    >
                        <div class="flex gap-4">
                            <a
                                target="_blank"
                                href="https://github.com/Pedrosandoval1"

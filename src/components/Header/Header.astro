                                        </g>
                                    </g>
                                </svg>
                            </a>
                            <!-- LinkedIn -->
                            <ContainerIconsDinamic
                                link="https://www.linkedin.com/in/pedro-sandoval-espinoza-576590191/"
                                colorSvg="white"
                            >
                                <path
                                    d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.11 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7.5 0h3.8v2.16h.05c.53-.99 1.82-2.04 3.75-2.04 4.01 0 4.75 2.64 4.75 6.07V24h-4v-7.28c0-1.74-.03-3.98-2.43-3.98-2.43 0-2.81 1.9-2.81 3.85V24h-4V8z"

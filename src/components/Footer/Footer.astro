---
import ContainerIconsDinamic from "../UI/ContainerIconsDinamic.astro";

// Footer.astro
const currentYear = new Date().getFullYear();
---

<footer
  class="bg-accent/5 overflow-hidden py-16 intersect-once intersect-quarter md:opacity-0 md:intersect:animate-fade"
>
  <div class="max-w-7xl mx-auto px-4">
    <!-- Contenedor de tres columnas -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <h4
        class="text-xl text-center font-semibold text-black-rich mb-4 text-white"
      >
        Redes sociales
        <!-- Columna 3: Redes Sociales -->
        <div class="mt-3">
          <div
            class="text-xl flex justify-center md:block font-semibold text-black-rich mb-0"
          >
            <div class="flex space-x-4">
              <!-- Twitter -->
              <ContainerIconsDinamic
                link="https://x.com/pedro_sand_espi"
                colorSvg="white"
              >
                <path
                  d="M22.46 6c-.77.35-1.6.58-2.46.69a4.3 4.3 0 001.88-2.37 8.59 8.59 0 01-2.72 1.04 4.28 4.28 0 00-7.3 3.9A12.13 12.13 0 013 4.79a4.28 4.28 0 001.32 5.71 4.24 4.24 0 01-1.94-.54v.05a4.28 4.28 0 003.43 4.19 4.29 4.29 0 01-1.93.07 4.28 4.28 0 004 2.98A8.6 8.6 0 012 19.54a12.15 12.15 0 006.56 1.92c7.88 0 12.2-6.53 12.2-12.2 0-.19 0-.39-.01-.58A8.72 8.72 0 0024 5.64a8.5 8.5 0 01-2.54.7z"
                ></path>
              </ContainerIconsDinamic>
              <!-- Facebook -->
              <ContainerIconsDinamic
                link="https://www.facebook.com/pedropablo.sandoval.39"
                colorSvg="white"
              >
                <path
                  d="M22 12a10 10 0 10-11.5 9.87v-6.99h-2.73V12h2.73V9.79c0-2.7 1.61-4.19 4.08-4.19 1.18 0 2.42.21 2.42.21v2.66h-1.37c-1.35 0-1.77.84-1.77 1.7V12h3l-.48 2.88h-2.52v6.99A10 10 0 0022 12z"
                ></path>
              </ContainerIconsDinamic>
              <!-- LinkedIn -->
              <ContainerIconsDinamic
                link="https://www.linkedin.com/in/pedro-sandoval-espinoza-576590191/"
                colorSvg="white"
              >
                <path
                  d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.11 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7.5 0h3.8v2.16h.05c.53-.99 1.82-2.04 3.75-2.04 4.01 0 4.75 2.64 4.75 6.07V24h-4v-7.28c0-1.74-.03-3.98-2.43-3.98-2.43 0-2.81 1.9-2.81 3.85V24h-4V8z"
                ></path>
              </ContainerIconsDinamic>
              <!-- Instagram -->
              <ContainerIconsDinamic
                link="https://www.instagram.com/pedropablo.sandoval.39/"
                colorSvg="white"
              >
                <path
                  d="M12 2.2c3.2 0 3.584.012 4.85.07 1.17.054 1.97.24 2.43.403.55.21.95.465 1.37.885.42.42.675.82.885 1.37.163.46.35 1.26.403 2.43.058 1.266.07 1.65.07 4.85s-.012 3.584-.07 4.85c-.054 1.17-.24 1.97-.403 2.43-.21.55-.465.95-.885 1.37-.42.42-.82.675-1.37.885-.46.163-1.26.35-2.43.403-1.266.058-1.65.07-4.85.07s-3.584-.012-4.85-.07c-1.17-.054-1.97-.24-2.43-.403-.55-.21-.95-.465-1.37-.885-.42-.42-.675-.82-.885-1.37-.163-.46-.35-1.26-.403-2.43C2.212 15.584 2.2 15.2 2.2 12s.012-3.584.07-4.85c.054-1.17.24-1.97.403-2.43.21-.55.465-.95.885-1.37.42-.42.82-.675 1.37-.885.46-.163 1.26-.35 2.43-.403C8.416 2.212 8.8 2.2 12 2.2zm0-2.2C8.735 0 8.332.012 7.052.07 5.772.128 4.822.317 4.008.632 3.16.95 2.49 1.42 1.86 2.05.232 3.677 0 5.318 0 12s.232 8.323 1.86 9.95c.63.63 1.3 1.1 2.148 1.418.814.315 1.764.504 3.044.562C8.332 23.988 8.735 24 12 24s3.668-.012 4.948-.07c1.28-.058 2.23-.247 3.044-.562.848-.318 1.518-.788 2.148-1.418C23.768 20.323 24 18.682 24 12s-.232-8.323-1.86-9.95c-.63-.63-1.3-1.1-2.148-1.418C19.178.317 18.228.128 16.948.07 15.668.012 15.265 0 12 0zM12 5.838A6.162 6.162 0 1 0 18.162 12 6.17 6.17 0 0 0 12 5.838zm0 10.162A3.999 3.999 0 1 1 16 12a3.999 3.999 0 0 1-4 4zm6.406-11.845a1.44 1.44 0 1 1-1.44-1.44 1.44 1.44 0 0 1 1.44 1.44z"
                ></path>
              </ContainerIconsDinamic>
            </div>
          </div>
          <!-- Separador y derechos de autor -->
          <div class="mt-6 border-t border-gray-200 pt-6 text-center">
            <p class="text-gray-elegant-700 text-sm text-white">
              &copy; {currentYear} Pedro Pablo Sandoval Espinoza. Todos los derechos
              reservados.
            </p>
          </div>
        </div>
      </h4>
    </div>
  </div>
</footer>
